{
  "name": "agua-global-server",
  "version": "1.0.0",
  "description": "Express and PostgreSQL API for AGUA Global water billing.",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:check": "node src/db/check.js",
    "db:migrate:billing": "node src/db/runSqlFile.js database/migrations/002_billing_periods_settings.sql",
    "db:migrate:meters": "node src/db/runSqlFile.js database/migrations/003_meters_reading_context.sql",
    "db:migrate:meter-events": "node src/db/runSqlFile.js database/migrations/004_meter_replacement_events.sql",
    "db:migrate:payments": "node src/db/runSqlFile.js database/migrations/005_receipt_level_payments.sql",
    "db:migrate:audit": "node src/db/runSqlFile.js database/migrations/006_audit_events.sql",
    "db:migrate:expenses": "node src/db/runSqlFile.js database/migrations/007_expenses.sql",
    "db:migrate:business-settings": "node src/db/runSqlFile.js database/migrations/008_business_settings.sql",
    "db:migrate:maintenance": "node src/db/runSqlFile.js database/migrations/009_maintenance_requests.sql",
    "db:migrate:tariffs": "node src/db/runSqlFile.js database/migrations/010_tariff_refinement.sql",
    "db:migrate:penalties": "node src/db/runSqlFile.js database/migrations/011_penalty_applications.sql",
    "db:migrate:user-password-policy": "node src/db/runSqlFile.js database/migrations/012_user_password_policy.sql",
    "db:migrate:customer-opening-balances": "node src/db/runSqlFile.js database/migrations/013_customer_opening_balances.sql",
    "db:migrate:migration-balance-bills": "node src/db/runSqlFile.js database/migrations/014_migration_balance_bills.sql",
    "db:migrate:customer-credits": "node src/db/runSqlFile.js database/migrations/015_customer_credits.sql",
    "db:migrate:numbering": "node src/db/runSqlFile.js database/migrations/016_numbering_and_account_closure.sql",
    "db:migrate:account-adjustments": "node src/db/runSqlFile.js database/migrations/017_account_closure_and_adjustments.sql",
    "db:migrate:penalty-policy": "node src/db/runSqlFile.js database/migrations/018_penalty_policy_and_waivers.sql",
    "payment:check": "node src/db/paymentCheck.js",
    "db:seed": "node src/db/seed.js"
