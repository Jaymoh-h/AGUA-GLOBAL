PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agua_global
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN=8h
CRON_SECRET=change-this-separate-cron-secret
REMINDER_CRON_SECRET=
MONITORING_CRON_SECRET=
MONITORING_ALERT_EMAILS=
MONITORING_ALERT_PHONES=
MONITORING_ALERT_WINDOW_MINUTES=15
MONITORING_ALERT_COOLDOWN_MINUTES=60
PUBLIC_STATUS_URL=
CLIENT_ORIGIN=http://localhost:5173
# For production subdomains, separate allowed browser origins with commas:
# CLIENT_ORIGIN=https://www.example.com,https://status.example.com,https://docs.example.com
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
LOGO_STORAGE_MODE=filesystem
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=180

# Email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SMS delivery
SMS_PROVIDER=none
SMS_DEFAULT_COUNTRY_CODE=254
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# WhatsApp delivery preparedness
WHATSAPP_PROVIDER=none
WHATSAPP_DEFAULT_COUNTRY_CODE=254
TWILIO_WHATSAPP_FROM=
WHATSAPP_TWILIO_ACCOUNT_SID=
WHATSAPP_TWILIO_AUTH_TOKEN=
WHATSAPP_TWILIO_FROM=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
